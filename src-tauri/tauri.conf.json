{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Soteria",
  "version": "0.1.0",
  "identifier": "com.marshsecurity.soteria",
  "build": {
    "beforeDevCommand": "npm --prefix ../ui run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "",
    "frontendDist": "../ui/dist"
},
  "app": {
    "windows": [
      {
        "title": "Soteria",
        "width": 1280,
        "height": 820,
        "minWidth": 1100,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
